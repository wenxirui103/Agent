# OpenAI 兼容协议的 LLM 配置模板
# 复制此文件为 .env 并填写正确的参数

# API 基础 URL (例如: http://localhost:11434/v1 用于 Ollama)
LLM_BASE_URL=http://localhost:11434/v1

# 模型名称 (例如: llama2, qwen2.5, gemma2, mistral 等)
LLM_MODEL=llama2

# API Token (如果不需要认证可以留空)
LLM_API_TOKEN=your_api_token_here

# AnythingLLM API Key (用于访问 AnythingLLM 知识库)
# 在 AnythingLLM 设置中生成，格式如: H52K9Y6-E5TM68E-M4ZXEEH-E7A4C7Q
ANYTHINGLLM_API_KEY=your-anythingllm-api-key-here

# 可选：超时设置（秒）
REQUEST_TIMEOUT=30

# 可选：最大 token 数
MAX_TOKENS=2048

# 可选：温度参数 (0.0-1.0，控制随机性)
TEMPERATURE=0.7

# 可选：Top-p 采样参数
TOP_P=0.9
